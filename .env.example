DISCORD_BOT_TOKEN=
HUGGINGFACE_API_TOKEN=
HF_ASR_MODEL=openai/whisper-small
HF_SUMMARY_MODEL=philschmid/bart-large-cnn-samsum
RECORDINGS_DIR=recordings
ASR_BACKEND=auto
LOCAL_ASR_MODEL=tiny.en
LOCAL_ASR_DEVICE=cpu
LOCAL_ASR_COMPUTE_TYPE=int8
LIVE_VOICE_ENABLED=false
LIVE_REQUIRE_WAKE_WORD=false
LIVE_TRANSCRIBE_SILENCE_SECONDS=2.0
LIVE_TRANSCRIBE_MIN_SECONDS=0.8
LIVE_TRANSCRIBE_MAX_SECONDS=12
LIVE_TRANSCRIBE_LANGUAGE=auto
LIVE_TEXT_FEEDBACK=false

# Wake word detection
WAKE_WORDS=hey bee,hey b,hey bot
VOICE_CHUNK_SECONDS=5
VOICE_POLL_SECONDS=1.5
MIN_RMS_FOR_TRANSCRIPTION=220

# OpenAI-compatible chat API, for example OpenRouter
AI_API_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=google/gemini-2.5-flash
AI_SITE_URL=
AI_APP_NAME=Bee Voice Bot
AI_TEMPERATURE=0.5
AI_MAX_TOKENS=40
AI_STYLE=normal
PERSIST_CHAT_MEMORY=true
CHAT_MEMORY_FILE=recordings/chat_memory.json

# Spoken reply voice
TTS_BACKEND=edge
LOCAL_TTS_MODEL_PATH=voices/en_US-lessac-low.onnx
TTS_VOICE=en-US-AriaNeural
MAX_TTS_CHARS=80
ACK_TTS_TEXT=Okay.
